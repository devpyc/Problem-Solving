#include <bits/stdc++.h>
using namespace std;

bool comp(int a, int b){
	int x=__builtin_popcount(a);
	int y=__builtin_popcount(b);
	if(x==y) return a>b;
	else return x>y;
}

int main(){
	cin.tie(0)->sync_with_stdio(0);

	int n,k;
	cin>>n>>k;

	int arr[n];
	for(int i=0; i<n; i++){
		cin>>arr[i];
	}

	sort(arr,arr+n,comp);
	cout<<arr[k-1];
}