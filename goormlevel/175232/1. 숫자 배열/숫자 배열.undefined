#include <bits/stdc++.h>
using namespace std;

int main() {
    cin.tie(0)->sync_with_stdio(0);

    int n;
    cin>>n;
    int arr[n][n];
    int x=1;
    for (int i=0; i<n; i++) {
        for (int j=0; j<n; j++) {
            cout<<x;
					if(j!=n-1) cout<<" ";
            x++;
        }
        cout<<"\n";
    }

}